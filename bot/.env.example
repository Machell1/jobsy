# === Deal Alert Bot Configuration ===

# Telegram Bot Token (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Telegram Channel ID (e.g., @yourchannel or -1001234567890)
TELEGRAM_CHANNEL_ID=@your_channel_here

# Telegram Channel Handle (used for link formatting)
TELEGRAM_CHANNEL_HANDLE=@your_channel_here

# === Affiliate Tags ===
# Sign up for each store's affiliate program to earn commissions.

# Amazon Associates (affiliate-program.amazon.com)
AMAZON_AFFILIATE_TAG=your-tag-20

# eBay Partner Network (partnernetwork.ebay.com)
EBAY_AFFILIATE_CAMPAIGN_ID=
EBAY_PARTNER_KEY=

# === Impact Radius (impact.com) ===
# Account-level credentials for the Impact API
IMPACT_ACCOUNT_SID=
IMPACT_AUTH_TOKEN=

# Per-brand campaign tracking tags from Impact dashboard
WALMART_AFFILIATE_TAG=
TARGET_AFFILIATE_TAG=
BESTBUY_AFFILIATE_TAG=
GROUPON_AFFILIATE_TAG=
SKYSCANNER_AFFILIATE_TAG=

# === CJ Affiliate (cj.com) ===
CJ_DEVELOPER_KEY=
CJ_WEBSITE_ID=
EXPEDIA_AFFILIATE_TAG=

# === X (Twitter) API ===
# Get these from developer.x.com (see README for setup steps)
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_POST_ENABLED=false

# === Telegram Bot Admin ===
# Comma-separated Telegram user IDs allowed to control the bot
# Get your ID by messaging @userinfobot on Telegram
ADMIN_USER_IDS=

# === Database ===
# Database file path (set to /data/deals.db on Railway with a volume mount)
# Leave empty to use default (deals.db in the bot directory)
DB_PATH=

# === Bot Settings ===
CHECK_INTERVAL_MINUTES=60
MIN_DROP_PERCENT=15
MIN_DROP_DOLLARS=5
DEFAULT_CONVERSION_RATE=0.02
DEFAULT_CTR=0.05
