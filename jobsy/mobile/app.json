{
  "expo": {
    "name": "Jobsy",
    "slug": "jobsy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "jobsy",
    "owner": "machell1",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#01696F"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jobsyja.app",
      "buildNumber": "1",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Jobsy needs camera access to take profile photos and upload service images",
        "NSPhotoLibraryUsageDescription": "Jobsy needs photo library access to select profile photos and service images",
        "NSLocationWhenInUseUsageDescription": "Jobsy uses your location to find service providers near you",
        "NSLocationAlwaysUsageDescription": "Jobsy uses your location to find nearby service providers",
        "NSPhotoLibraryAddUsageDescription": "Jobsy needs permission to save images to your photo library",
        "ITSAppUsesNonExemptEncryption": false
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#01696F"
      },
      "package": "com.jobsyja.app",
      "versionCode": 1,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES",
        "INTERNET",
        "RECEIVE_BOOT_COMPLETED"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      "expo-secure-store",
      "expo-location",
      "expo-image-picker",
      "expo-notifications",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#01696F"
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": ""
      }
    }
  }
}
