{
  "expo": {
    "name": "Jobsy",
    "slug": "jobsy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "jobsy",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B5E20"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.williamsmachell.jobsy",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Jobsy needs your location to show nearby services in your parish.",
        "NSCameraUsageDescription": "Jobsy needs camera access to take profile and listing photos.",
        "NSPhotoLibraryUsageDescription": "Jobsy needs photo library access to upload images."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1B5E20"
      },
      "package": "com.jobsy.app",
      "permissions": ["ACCESS_FINE_LOCATION", "CAMERA", "READ_EXTERNAL_STORAGE"]
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      "expo-secure-store",
      "expo-location",
      "expo-image-picker",
      "expo-notifications",
      [
        "expo-splash-screen",
        { "backgroundColor": "#1B5E20" }
      ]
    ]
  }
}
