# =============================================================================
# Jobsy - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Default values are suitable for local development with docker-compose.

# --- Database (PostgreSQL with PostGIS) ---
DATABASE_URL=postgresql+asyncpg://jobsy:localdev@localhost:5432/jobsy

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- RabbitMQ ---
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# --- JWT Authentication ---
# IMPORTANT: Change this in production!
JWT_SECRET=local-dev-secret-change-in-production
JWT_ACCESS_EXPIRY_MINUTES=60
JWT_REFRESH_EXPIRY_DAYS=30

# --- Internal Service URLs (for gateway routing) ---
# These are set automatically in docker-compose.yml
PROFILES_SERVICE_URL=http://localhost:8001
LISTINGS_SERVICE_URL=http://localhost:8002
SWIPES_SERVICE_URL=http://localhost:8003
MATCHES_SERVICE_URL=http://localhost:8004
GEOSHARD_SERVICE_URL=http://localhost:8005
RECOMMENDATIONS_SERVICE_URL=http://localhost:8006
CHAT_SERVICE_URL=http://localhost:8007
NOTIFICATIONS_SERVICE_URL=http://localhost:8008
STORAGE_SERVICE_URL=http://localhost:8009
ADVERTISING_SERVICE_URL=http://localhost:8010
PAYMENTS_SERVICE_URL=http://localhost:8011
REVIEWS_SERVICE_URL=http://localhost:8012
SEARCH_SERVICE_URL=http://localhost:8013
ADMIN_SERVICE_URL=http://localhost:8014

# --- Object Storage (MinIO / S3) ---
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=jobsy
S3_REGION=us-east-1
S3_PUBLIC_URL=http://localhost:9000/jobsy

# --- Elasticsearch ---
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=

# --- Stripe Payments ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
PLATFORM_FEE_PERCENT=10
STRIPE_REFRESH_URL=https://yourdomain.com/payments/refresh
STRIPE_RETURN_URL=https://yourdomain.com/payments/complete

# --- Firebase Push Notifications ---
# Paste the full service account JSON on one line:
FIREBASE_CREDENTIALS_JSON={"type": "service_account", ...}

# --- Expo Push Notifications ---
EXPO_ACCESS_TOKEN=your_expo_access_token

# --- Google OAuth (Social Login) ---
GOOGLE_CLIENT_ID=868545444077-unsoo0vl887552vfvl2029dg2bh8mfs8.apps.googleusercontent.com

# --- Apple Sign In ---
APPLE_BUNDLE_ID=com.williamsmachell.jobsy
APPLE_TEAM_ID=K6TZR6QQGS

# --- Twilio SMS Verification ---
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# --- Cloudinary (Image Hosting) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Sentry (Error Monitoring) ---
SENTRY_DSN=

# --- Resend (Transactional Email) ---
RESEND_API_KEY=

# --- SendGrid (Email Fallback) ---
SENDGRID_API_KEY=

# --- Mapbox (Location Services) ---
MAPBOX_PUBLIC_TOKEN=
MAPBOX_SECRET_TOKEN=

# --- PayPal (Alternative Payments) ---
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# --- PostHog (Product Analytics) ---
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# --- Slack (Alerting) ---
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_DEFAULT_CHANNEL=#alerts

# --- Stream Chat (Real-time Messaging) ---
STREAM_API_KEY=your_stream_api_key
STREAM_API_SECRET=your_stream_api_secret

# --- Admin Bootstrap ---
ADMIN_BOOTSTRAP_SECRET=change-this-in-production

# --- Additional Service URLs ---
BOOKINGS_SERVICE_URL=http://localhost:8015
NOTICEBOARD_SERVICE_URL=http://localhost:8016

# --- Rate Limiting ---
RATE_LIMIT_UNAUTH=30
RATE_LIMIT_AUTH=100
RATE_LIMIT_AUTH_ENDPOINTS=10

# --- SMTP (Email Fallback) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@jobsyja.com

# --- Revive Adserver (optional -- falls back to local campaigns) ---
# REVIVE_BASE_URL=http://localhost:8080
# REVIVE_API_KEY=
